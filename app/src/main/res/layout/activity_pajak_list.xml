<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070A12"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="44dp"
        android:paddingEnd="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/history_tax_title"
            android:textColor="#F4F5FA"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="88dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card_dark"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:background="@drawable/bg_circle_yellow"
                android:gravity="center"
                android:text="@string/catat_pajak_short"
                android:textColor="#070A12"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/tax_next_title"
                    android:textColor="#F4F5FA"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textPajakSummaryMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="#9AA0B5"
                    android:textSize="13sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/textPajakSummaryValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#F4F5FA"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tabRiwayatServis"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_segment_active"
                android:gravity="center"
                android:text="@string/servis_label"
                android:textColor="#F4F5FA"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tabRiwayatOli"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_segment_active"
                android:gravity="center"
                android:text="@string/oli_label"
                android:textColor="#F4F5FA"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tabRiwayatBensin"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:background="@drawable/bg_segment_active"
                android:gravity="center"
                android:text="@string/bensin_label"
                android:textColor="#F4F5FA"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tabRiwayatPajak"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/bg_circle_yellow"
                android:gravity="center"
                android:text="@string/pajak_label"
                android:textColor="#070A12"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/buttonAddPajak"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:backgroundTint="#FFCB25"
            android:text="@string/add_tax_record"
            android:textColor="#070A12"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textEmptyPajak"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="@string/empty_pajak"
            android:textColor="#9AA0B5" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPajak"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="14dp"
            android:layout_weight="1" />
    </LinearLayout>

    <include layout="@layout/include_bottom_nav" />
</LinearLayout>

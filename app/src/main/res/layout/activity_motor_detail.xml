<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070A12"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="18dp"
        android:paddingEnd="22dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/motor_detail_title"
            android:textColor="#F4F5FA"
            android:textSize="26sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="148dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_card_dark">

            <TextView
                android:id="@+id/textDetailMotorName"
                android:layout_width="170dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="22dp"
                android:textColor="#F4F5FA"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textDetailPlateNumber"
                android:layout_width="170dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="22dp"
                android:layout_marginTop="48dp"
                android:textColor="#9AA0B5"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/textDetailKilometer"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="22dp"
                android:layout_marginEnd="16dp"
                android:gravity="end"
                android:textColor="#F4F5FA"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="48dp"
                android:layout_marginEnd="16dp"
                android:gravity="end"
                android:text="@string/km_current_label"
                android:textColor="#9AA0B5"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/textDetailActive"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="68dp"
                android:layout_marginEnd="16dp"
                android:gravity="end"
                android:textColor="#FFCB25"
                android:textSize="12sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_gravity="bottom"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:layout_marginBottom="14dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/buttonEditMotor"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#FFCB25"
                    android:text="@string/edit"
                    android:textColor="#070A12"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/buttonSetActiveMotor"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    android:backgroundTint="#FFCB25"
                    android:text="@string/set_active_motor_short"
                    android:textColor="#070A12"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/buttonDeleteMotor"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="8dp"
                    android:layout_weight="1"
                    android:backgroundTint="#333541"
                    android:text="@string/delete"
                    android:textColor="#F4F5FA"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/summary_title"
            android:textColor="#F4F5FA"
            android:textSize="21sp"
            android:textStyle="bold" />

        <TextView
            style="@style/MotorSummaryRow"
            android:layout_marginTop="14dp"
            android:drawableStart="@drawable/ic_service"
            android:text="@string/service_summary_placeholder" />

        <TextView
            style="@style/MotorSummaryRow"
            android:drawableStart="@drawable/ic_oil"
            android:text="@string/oil_summary_placeholder" />

        <TextView
            style="@style/MotorSummaryRow"
            android:drawableStart="@drawable/ic_tax"
            android:text="@string/tax_summary_placeholder" />
    </LinearLayout>

    <include layout="@layout/include_bottom_nav" />

</LinearLayout>

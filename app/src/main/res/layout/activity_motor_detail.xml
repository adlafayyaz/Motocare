<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070A12"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="40dp"
        android:paddingEnd="22dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/motor_detail_title"
            android:textColor="#F4F5FA"
            android:textSize="26sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_card_dark">

            <TextView
                android:id="@+id/textDetailActive"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_circle_yellow"
                android:gravity="center"
                android:textColor="#070A12"
                android:textSize="1sp" />

            <TextView
                android:id="@+id/textDetailMotorName"
                android:layout_width="145dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="86dp"
                android:layout_marginTop="22dp"
                android:textColor="#F4F5FA"
                android:textSize="19sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textDetailPlateNumber"
                android:layout_width="145dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="86dp"
                android:layout_marginTop="48dp"
                android:textColor="#9AA0B5"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/textDetailKilometer"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="22dp"
                android:layout_marginEnd="16dp"
                android:gravity="end"
                android:textColor="#F4F5FA"
                android:textSize="17sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="48dp"
                android:layout_marginEnd="16dp"
                android:gravity="end"
                android:text="@string/km_current_label"
                android:textColor="#9AA0B5"
                android:textSize="11sp" />

            <Button
                android:id="@+id/buttonEditMotor"
                android:layout_width="82dp"
                android:layout_height="38dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginEnd="46dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#FFCB25"
                android:text="@string/edit"
                android:textColor="#070A12"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonDeleteMotor"
                android:layout_width="82dp"
                android:layout_height="38dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginStart="134dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#333541"
                android:text="@string/delete"
                android:textColor="#F4F5FA"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/buttonSetActiveMotor"
                android:layout_width="1dp"
                android:layout_height="1dp"
                android:visibility="invisible" />
        </FrameLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/summary_title"
            android:textColor="#F4F5FA"
            android:textSize="21sp"
            android:textStyle="bold" />

        <TextView
            style="@style/MotorSummaryRow"
            android:layout_marginTop="14dp"
            android:drawableStart="@drawable/ic_service"
            android:text="@string/service_summary_placeholder" />

        <TextView
            style="@style/MotorSummaryRow"
            android:drawableStart="@drawable/ic_oil"
            android:text="@string/oil_summary_placeholder" />

        <TextView
            style="@style/MotorSummaryRow"
            android:drawableStart="@drawable/ic_tax"
            android:text="@string/tax_summary_placeholder" />
    </LinearLayout>

    <include layout="@layout/include_bottom_nav" />

</LinearLayout>

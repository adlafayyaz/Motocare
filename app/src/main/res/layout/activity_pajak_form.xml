<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070A12">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="18dp"
        android:paddingEnd="22dp"
        android:paddingBottom="22dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:text="@string/tax_form_title"
            android:textColor="#F4F5FA"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textPajakMotor"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card_dark"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#FFCB25"
            android:textStyle="bold" />

        <TextView style="@style/FormLabel" android:text="@string/tax_due_date" />
        <EditText
            android:id="@+id/editPajakDueDate"
            style="@style/FormInput"
            android:hint="@string/date_hint"
            android:inputType="date" />

        <TextView style="@style/FormLabel" android:text="@string/tax_cost" />
        <EditText
            android:id="@+id/editPajakCost"
            style="@style/FormInput"
            android:hint="@string/tax_cost_hint"
            android:inputType="number" />

        <TextView style="@style/FormLabel" android:text="@string/tax_status" />
        <EditText
            android:id="@+id/editPajakStatus"
            style="@style/FormInput"
            android:hint="@string/default_tax_status"
            android:inputType="textCapWords" />

        <Button
            android:id="@+id/buttonSavePajak"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:backgroundTint="#FFCB25"
            android:text="@string/save"
            android:textColor="#070A12"
            android:textStyle="bold" />

        <Button
            android:id="@+id/buttonDeletePajak"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#2A2D3B"
            android:text="@string/delete"
            android:textColor="#F23D47"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070A12">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="18dp"
        android:paddingEnd="22dp"
        android:paddingBottom="22dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/buttonBack"
                android:layout_width="24dp"
                android:layout_height="match_parent"
                android:clickable="true"
                android:contentDescription="@string/back"
                android:focusable="true"
                android:padding="5dp"
                android:src="@drawable/ic_back"
                android:tint="#F4F5FA" />

            <TextView
                android:id="@+id/textTitleBack"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="@string/tax_form_title"
                android:textColor="#F4F5FA"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/textPajakMotor"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_card_dark"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#FFCB25"
            android:textStyle="bold" />

        <TextView style="@style/FormLabel" android:text="@string/tax_type" />
        <EditText
            android:id="@+id/editPajakType"
            style="@style/FormInput"
            android:clickable="true"
            android:focusable="false"
            android:hint="@string/default_tax_type"
            android:inputType="textCapWords" />

        <TextView style="@style/FormLabel" android:text="@string/tax_due_date" />
        <EditText
            android:id="@+id/editPajakDueDate"
            style="@style/FormInput"
            android:clickable="true"
            android:focusable="false"
            android:hint="@string/date_hint"
            android:inputType="date" />

        <TextView style="@style/FormLabel" android:text="@string/tax_cost" />
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="64dp">

            <EditText
                android:id="@+id/editPajakCost"
                style="@style/FormInputWithUnit"
                android:hint="@string/tax_cost_hint"
                android:inputType="number" />

            <TextView
                style="@style/FormUnitText"
                android:text="@string/unit_rp" />
        </FrameLayout>

        <TextView style="@style/FormLabel" android:text="@string/tax_status" />
        <EditText
            android:id="@+id/editPajakStatus"
            style="@style/FormInput"
            android:clickable="true"
            android:focusable="false"
            android:hint="@string/default_tax_status"
            android:inputType="textCapWords" />

        <Button
            android:id="@+id/buttonSavePajak"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:backgroundTint="#FFCB25"
            android:text="@string/save"
            android:textColor="#070A12"
            android:textStyle="bold" />

        <Button
            android:id="@+id/buttonDeletePajak"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:backgroundTint="#2A2D3B"
            android:text="@string/delete"
            android:textColor="#F23D47"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>

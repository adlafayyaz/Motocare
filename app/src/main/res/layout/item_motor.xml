<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="88dp"
    android:layout_marginBottom="14dp"
    android:background="@drawable/bg_card_dark"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="22dp"
    android:paddingEnd="16dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textMotorName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F4F5FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textMotorPlate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textColor="#9AA0B5"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="104dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textMotorKilometer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="#F4F5FA"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textMotorActive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:text="@string/motor_active_short"
            android:textColor="#FFCB25"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>

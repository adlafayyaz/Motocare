<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_dark"
    android:orientation="vertical"
    android:padding="18dp">

    <TextView
        android:id="@+id/textMotorName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#F4F5FA"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textMotorPlate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#9AA0B5"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/textMotorKilometer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="#F4F5FA"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textMotorActive"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/motor_active"
        android:textColor="#FFCB25"
        android:textSize="12sp"
        android:textStyle="bold" />

</LinearLayout>

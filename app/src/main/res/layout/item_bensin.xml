<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="78dp"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_card_dark"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="14dp">

    <TextView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/bg_dot_orange"
        android:gravity="center"
        android:text="B"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textBensinTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F4F5FA"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textBensinMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#9AA0B5"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textBensinCost"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#F4F5FA"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textBensinDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#FFCB25"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>

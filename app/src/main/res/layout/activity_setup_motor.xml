<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070A12">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="30dp"
        android:paddingTop="58dp"
        android:paddingEnd="30dp"
        android:paddingBottom="34dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_motor_title"
            android:textColor="#F4F5FA"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:lineSpacingExtra="4dp"
            android:text="@string/setup_motor_body"
            android:textColor="#9AA0B5"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="@string/motor_name"
            android:textColor="#F4F5FA"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editMotorName"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_dark"
            android:inputType="textCapWords"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#F4F5FA"
            android:textColorHint="#8B91A5"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/plate_number"
            android:textColor="#F4F5FA"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editPlateNumber"
            android:layout_width="match_parent"
            android:layout_height="62dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_input_dark"
            android:inputType="textCapCharacters"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:textColor="#F4F5FA"
            android:textColorHint="#8B91A5"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="@string/current_kilometer"
            android:textColor="#F4F5FA"
            android:textSize="15sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="70dp">

            <EditText
                android:id="@+id/editCurrentKilometer"
                style="@style/FormInputWithUnit"
                android:layout_height="62dp"
                android:layout_marginTop="10dp"
                android:textSize="16sp"
                android:inputType="number" />

            <TextView
                style="@style/FormUnitText"
                android:layout_height="62dp"
                android:layout_marginTop="10dp"
                android:text="@string/unit_km" />
        </FrameLayout>

        <Button
            android:id="@+id/buttonSaveMotor"
            android:layout_width="match_parent"
            android:layout_height="66dp"
            android:layout_marginTop="42dp"
            android:backgroundTint="#FFCB25"
            android:text="@string/save"
            android:textColor="#070A12"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="112dp"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_card_dark"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="22dp"
            android:paddingEnd="22dp">

            <TextView
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_circle_yellow"
                android:gravity="center"
                android:text="i"
                android:textColor="#070A12"
                android:textSize="28sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_schedule_title"
                    android:textColor="#F4F5FA"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/setup_schedule_body"
                    android:textColor="#9AA0B5"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="112dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card_dark"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="22dp"
            android:paddingEnd="22dp">

            <TextView
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_circle_yellow"
                android:gravity="center"
                android:text="i"
                android:textColor="#070A12"
                android:textSize="28sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_reminder_title"
                    android:textColor="#F4F5FA"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/setup_reminder_body"
                    android:textColor="#9AA0B5"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="112dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_card_dark"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="22dp"
            android:paddingEnd="22dp">

            <TextView
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_circle_yellow"
                android:gravity="center"
                android:text="i"
                android:textColor="#070A12"
                android:textSize="28sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/setup_tax_title"
                    android:textColor="#F4F5FA"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="2dp"
                    android:text="@string/setup_tax_body"
                    android:textColor="#9AA0B5"
                    android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</ScrollView>

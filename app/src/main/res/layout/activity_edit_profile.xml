<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070A12">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="18dp"
            android:paddingEnd="22dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/buttonBack"
                    android:layout_width="24dp"
                    android:layout_height="match_parent"
                    android:clickable="true"
                    android:contentDescription="@string/back"
                    android:focusable="true"
                    android:padding="5dp"
                    android:src="@drawable/ic_back"
                    android:tint="#F4F5FA" />

                <TextView
                    android:id="@+id/textTitleBack"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:text="@string/edit_profile_title"
                    android:textColor="#F4F5FA"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="78dp"
                android:layout_height="78dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_circle_yellow">

                <ImageView
                    android:id="@+id/imageEditProfileAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_circle_yellow"
                    android:clipToOutline="true"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_user" />

                <TextView
                    android:id="@+id/textEditProfileInitial"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textColor="#070A12"
                    android:textSize="26sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <TextView
                style="@style/FormLabel"
                android:layout_marginTop="34dp"
                android:text="@string/profile_name" />

            <EditText
                android:id="@+id/editProfileName"
                style="@style/FormInput"
                android:hint="@string/profile_name_hint"
                android:inputType="textCapWords" />

            <TextView
                style="@style/FormLabel"
                android:text="@string/profile_email" />

            <TextView
                android:id="@+id/textProfileEmail"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_dark"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#9AA0B5"
                android:textSize="15sp" />

            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/buttonSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="52dp"
                android:backgroundTint="#FFCB25"
                android:text="@string/save"
                android:textColor="#070A12"
                android:textStyle="bold" />
        </LinearLayout>

        <include layout="@layout/include_bottom_nav" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

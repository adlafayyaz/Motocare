<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070A12"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="34dp"
        android:paddingEnd="22dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/catat_title"
            android:textColor="#F4F5FA"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/catat_subtitle"
            android:textColor="#9AA0B5"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/buttonCatatMotor"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card_dark"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="18dp"
            android:paddingEnd="18dp">

            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle_yellow">

                <ImageView
                    android:layout_width="23dp"
                    android:layout_height="23dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/nav_motor_label"
                    android:src="@drawable/ic_motor"
                    android:tint="#070A12" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/textCatatMotorName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#F4F5FA"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textCatatMotorPlate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:textColor="#9AA0B5"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/change_motor"
                android:textColor="#FFCB25"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:columnCount="2"
            android:rowCount="2">

            <TextView
                android:id="@+id/buttonCatatServis"
                style="@style/CatatActionCard"
                android:drawableTop="@drawable/ic_service"
                android:text="@string/catat_servis" />

            <TextView
                android:id="@+id/buttonCatatOli"
                style="@style/CatatActionCard"
                android:drawableTop="@drawable/ic_oil"
                android:text="@string/catat_oli" />

            <TextView
                android:id="@+id/buttonCatatBensin"
                style="@style/CatatActionCard"
                android:drawableTop="@drawable/ic_fuel"
                android:text="@string/catat_bensin" />

            <TextView
                android:id="@+id/buttonCatatPajak"
                style="@style/CatatActionCard"
                android:drawableTop="@drawable/ic_tax"
                android:text="@string/catat_pajak" />
        </GridLayout>
    </LinearLayout>

    <include layout="@layout/include_bottom_nav" />
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#070A12"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingTop="18dp"
        android:paddingEnd="22dp"
        android:paddingBottom="22dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/buttonBack"
                android:layout_width="24dp"
                android:layout_height="match_parent"
                android:clickable="true"
                android:contentDescription="@string/back"
                android:focusable="true"
                android:padding="5dp"
                android:src="@drawable/ic_back"
                android:tint="#F4F5FA" />

            <TextView
                android:id="@+id/textDetailOliType"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:textColor="#F4F5FA"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:background="@drawable/bg_card_dark"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/textDetailOliNext"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFCB25"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textDetailOliDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="#F4F5FA"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/textDetailOliKm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#9AA0B5" />

        <TextView
            android:id="@+id/textDetailOliCost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="#9AA0B5" />
    </LinearLayout>

    <Button
        android:id="@+id/buttonEditOli"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="26dp"
        android:backgroundTint="#FFCB25"
        android:text="@string/edit"
        android:textColor="#070A12"
        android:textStyle="bold" />

    <Button
        android:id="@+id/buttonDeleteOliDetail"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginTop="10dp"
        android:backgroundTint="#2A2D3B"
        android:text="@string/delete"
        android:textColor="#F23D47"
        android:textStyle="bold" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070A12"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="50dp"
    android:paddingEnd="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_greeting"
                android:textColor="#8B91A5"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/dashboard"
                android:textColor="#F4F5FA"
                android:textSize="32sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:background="@drawable/bg_circle_yellow"
            android:gravity="center"
            android:text="@string/profile_initial"
            android:textColor="#070A12"
            android:textSize="19sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:background="@drawable/bg_card_dark"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/textDashboardMotorName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F4F5FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textDashboardMotorPlate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#9AA0B5"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/textDashboardKilometer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textColor="#FFCB25"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/buttonDashboardAddMotor"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="#FFCB25"
            android:text="@string/add_motor"
            android:textColor="#070A12"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_card_dark"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="14dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_motor"
            android:textColor="#070A12"
            android:textStyle="bold"
            android:background="@drawable/bg_circle_yellow" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/catat_servis_short"
            android:textColor="#F4F5FA"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/catat_oli_short"
            android:textColor="#F4F5FA"
            android:textStyle="bold" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/catat_pajak_short"
            android:textColor="#F4F5FA"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_card_dark"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/monthly_expense"
            android:textColor="#9AA0B5"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/textMonthlyTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#F4F5FA"
            android:textSize="30sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/textNextService"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_card_dark"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:textColor="#F4F5FA"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textFuelTotal"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_marginTop="14dp"
        android:textColor="#F4F5FA"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textTaxTotal"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:textColor="#9AA0B5"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textOilTotal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:textColor="#9AA0B5"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_home"
            android:textColor="#FFCB25"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/navMotor"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_motor"
            android:textColor="#8B91A5"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/navCatat"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/bg_circle_yellow"
            android:gravity="center"
            android:text="@string/nav_add"
            android:textColor="#070A12"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/navRiwayat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_riwayat"
            android:textColor="#8B91A5"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_profile"
            android:textColor="#8B91A5"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>

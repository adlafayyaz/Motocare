<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070A12"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:text="@string/dashboard"
        android:textColor="#F4F5FA"
        android:textSize="30sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:background="@drawable/bg_card_dark"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/textDashboardMotorName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F4F5FA"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textDashboardMotorPlate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="#9AA0B5"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/textDashboardKilometer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textColor="#FFCB25"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/buttonDashboardAddMotor"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="#FFCB25"
            android:text="@string/add_motor"
            android:textColor="#070A12"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_card_dark"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/monthly_expense"
            android:textColor="#9AA0B5"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/textMonthlyTotal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#F4F5FA"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textNextService"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#FFCB25"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/textFuelTotal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:textColor="#F4F5FA"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textTaxTotal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="#F4F5FA"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textOilTotal"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:textColor="#F4F5FA"
        android:textSize="14sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_home"
            android:textColor="#FFCB25"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/navMotor"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="@string/nav_motor"
            android:textColor="#8B91A5"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/navCatat"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_circle_yellow"
            android:gravity="center"
            android:text="@string/nav_add"
            android:textColor="#070A12"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>

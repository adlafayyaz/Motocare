<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#090C14"
    android:orientation="vertical"
    android:paddingStart="22dp"
    android:paddingTop="10dp"
    android:paddingEnd="22dp"
    android:paddingBottom="28dp">

    <View
        android:layout_width="54dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_sheet_handle" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="@string/catat_vehicle_title"
        android:textColor="#F4F5FA"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/catat_vehicle_subtitle"
        android:textColor="#9AA0B5"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/sheetMotorSelector"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_card_dark"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textSheetMotorName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#F4F5FA"
                android:textSize="15sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textSheetMotorMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#9AA0B5"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/textSheetChangeMotor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/change_motor"
            android:textColor="#FFCB25"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:columnCount="2">

        <TextView
            android:id="@+id/sheetActionServis"
            style="@style/SheetActionCard"
            android:drawableStart="@drawable/ic_service"
            android:drawableTint="#FFCB25"
            android:text="@string/servis_label" />

        <TextView
            android:id="@+id/sheetActionOli"
            style="@style/SheetActionCard"
            android:drawableStart="@drawable/ic_oil"
            android:drawableTint="#6045F4"
            android:text="@string/oli_label" />

        <TextView
            android:id="@+id/sheetActionBensin"
            style="@style/SheetActionCard"
            android:drawableStart="@drawable/ic_fuel"
            android:drawableTint="#FF7D19"
            android:text="@string/bensin_label" />

        <TextView
            android:id="@+id/sheetActionPajak"
            style="@style/SheetActionCard"
            android:drawableStart="@drawable/ic_tax"
            android:drawableTint="#FFCB25"
            android:text="@string/pajak_label" />
    </GridLayout>

    <TextView
        android:id="@+id/sheetAddMotor"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:visibility="gone" />
</LinearLayout>

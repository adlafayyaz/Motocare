<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#070A12">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="18dp"
        android:paddingEnd="24dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/buttonBack"
                android:layout_width="24dp"
                android:layout_height="match_parent"
                android:clickable="true"
                android:contentDescription="@string/back"
                android:focusable="true"
                android:padding="5dp"
                android:src="@drawable/ic_back"
                app:tint="#F4F5FA" />

            <TextView
                android:id="@+id/textTitleBack"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:text="@string/motor_form_title"
                android:textColor="#F4F5FA"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="26dp"
            android:text="@string/motor_name"
            android:textColor="#F4F5FA"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editMotorName"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_dark"
            android:inputType="textCapWords"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#F4F5FA"
            android:textColorHint="#8B91A5" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/plate_number"
            android:textColor="#F4F5FA"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/editPlateNumber"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_input_dark"
            android:inputType="textCapCharacters"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:textColor="#F4F5FA"
            android:textColorHint="#8B91A5" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/current_kilometer"
            android:textColor="#F4F5FA"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="66dp">

            <EditText
                android:id="@+id/editCurrentKilometer"
                style="@style/FormInputWithUnit"
                android:layout_height="58dp"
                android:inputType="number" />

            <TextView
                style="@style/FormUnitText"
                android:layout_height="58dp"
                android:text="@string/unit_km" />
        </FrameLayout>

        <Button
            android:id="@+id/buttonSaveMotor"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="42dp"
            android:backgroundTint="#FFCB25"
            android:text="@string/save"
            android:textColor="#070A12"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
